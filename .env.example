# OpenAI API Configuration
QUERY_ENGINE_OPENAI_API_KEY=sk-your-api-key-here

# OpenAI Model Settings (optional)
QUERY_ENGINE_OPENAI_MODEL=gpt-4
QUERY_ENGINE_OPENAI_TEMPERATURE=0.0
QUERY_ENGINE_OPENAI_MAX_TOKENS=2000

# Query Execution Settings (optional)
QUERY_ENGINE_QUERY_TIMEOUT_SECONDS=30
QUERY_ENGINE_MAX_DEBUG_ATTEMPTS=3

# Datasource Settings (optional)
# QUERY_ENGINE_DATASOURCE_PATH=./data/sales.parquet
# QUERY_ENGINE_DATASOURCE_TYPE=parquet

# Operational Settings (optional)
QUERY_ENGINE_LOG_LEVEL=INFO
QUERY_ENGINE_LOG_QUERIES=true
