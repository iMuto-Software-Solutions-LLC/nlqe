[run]
omit =
    src/query_engine/openai/client.py
    src/query_engine/openai/__init__.py
    src/query_engine/testing/__init__.py
    src/query_engine/utils/logging.py
    
[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if __name__ == .__main__.:
    if 0:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod
    except Exception as e: